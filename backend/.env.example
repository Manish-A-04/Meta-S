DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/metas

JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

REDIS_URL=redis://localhost:6379/0

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3.5:3.8b

EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

MAX_CONTEXT_TOKENS=2048
MAX_REFLECTION_LOOPS=2

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── IMAP Settings ─────────────────────────────────────────────────────────────
# Gmail: enable IMAP in Settings → Forwarding & POP/IMAP
# Use an App Password (NOT your regular password):
# myaccount.google.com/apppasswords → Create app password for "Mail"
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=yourname@gmail.com
IMAP_PASSWORD=your_app_password_here

# Mailbox to fetch from (usually INBOX)
IMAP_MAILBOX=INBOX

# Number of most-recent emails to load on first fetch
INITIAL_FETCH_COUNT=100

# Max emails per IMAP batch (Gmail free tier: keep ≤ 50 to avoid rate limits)
IMAP_BATCH_SIZE=50

# Set to True to auto-fetch emails on every server startup.
# Set to False (default) to require manual trigger: POST /api/v1/emails/fetch
IMAP_AUTO_LOAD_ON_STARTUP=False

# ── Priority Engine ───────────────────────────────────────────────────────────
PRIORITY_CRITICAL_THRESHOLD=90
PRIORITY_HIGH_THRESHOLD=70
PRIORITY_MEDIUM_THRESHOLD=40
